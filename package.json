{
  "name": "shipguard-cli",
  "version": "2.0.0",
  "description": "AI-powered security scanner with Claude API integration and MCP server support",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./mcp": "./dist/mcp/server.js"
  },
  "bin": {
    "shipguard": "dist/cli.js",
    "shipguard-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "shipguard-rules.example.yml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node -- src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "security",
    "scanner",
    "cli",
    "claude",
    "anthropic",
    "mcp",
    "model-context-protocol",
    "devsecops",
    "sarif",
    "ai",
    "static-analysis",
    "vulnerability"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ykavak-dev/ShipGuard.git"
  },
  "homepage": "https://github.com/ykavak-dev/ShipGuard",
  "bugs": {
    "url": "https://github.com/ykavak-dev/ShipGuard/issues"
  },
  "author": "Yigit Kavak",
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.78.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "4.1.2",
    "commander": "^11.0.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "ora": "5.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
